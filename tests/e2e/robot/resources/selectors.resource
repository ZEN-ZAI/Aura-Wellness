*** Settings ***
Documentation    Reusable Ant Design component selectors.


*** Variables ***
# Layout
${ANT_TABLE}              css=.ant-table-wrapper
${ANT_TABLE_ROW}          css=.ant-table-row
${ANT_MODAL}              css=.ant-modal-container
${ANT_MODAL_WRAP}         css=.ant-modal-wrap
${ANT_MODAL_FOOTER}       css=.ant-modal-footer
${ANT_DRAWER}             css=.ant-drawer-content

# Feedback
${ANT_ALERT_ERROR}        css=.ant-alert-error
${ANT_ALERT_SUCCESS}      css=.ant-alert-success
${ANT_RESULT_SUCCESS}     css=.ant-result-success
${ANT_FORM_ERROR}         css=.ant-form-item-explain-error
${ANT_SPIN}               css=.ant-spin-spinning

# Form components
${ANT_SELECT_SELECTOR}    css=.ant-select-content
${ANT_SELECT_DROPDOWN}    css=.ant-select-dropdown
${ANT_SELECT_OPTION}      css=.ant-select-item-option

# Data display
${ANT_LIST}               css=.ant-list
${ANT_CARD}               css=.ant-card
${ANT_TAG}                css=.ant-tag
${ANT_SWITCH}             css=button[role="switch"]
${ANT_SWITCH_ON}          css=button[role="switch"][aria-checked="true"]
${ANT_SWITCH_OFF}         css=button[role="switch"][aria-checked="false"]

# Statistics
${ANT_STATISTIC}          css=.ant-statistic
